   wire [27:0] axi4lite_master_araddr;
   wire        axi4lite_master_arready;
   wire        axi4lite_master_rvalid;
   wire [1:0]  axi4lite_master_rresp;
   wire [31:0] axi4lite_master_rdata;
   wire        axi4lite_master_rready;

   // [RADAR] IRQ wire from radar IP to interrupt bus
   wire        radar_irq;

  // ================================================================
  // SPI0 wires
  // ================================================================
   wire spi0_io_mosi_out, spi0_io_mosi_outen, spi0_io_mosi_in_val;
   wire spi0_io_miso_out, spi0_io_miso_outen, spi0_io_miso_in_val;
   wire spi0_io_nss_out,  spi0_io_nss_outen,  spi0_io_nss_in_val;
   wire spi0_io_sclk_out, spi0_io_sclk_outen, spi0_io_sclk_in_val;

  wire [31:0] temp_s_axi_awaddr, temp_s_axi_araddr;
  assign s_axi_awaddr = temp_s_axi_awaddr [AXI_ADDR_WIDTH-1:0];
  assign s_axi_araddr = temp_s_axi_araddr [AXI_ADDR_WIDTH-1:0];

  proc_sys_reset_0 proc_reset_inst (
      .slowest_sync_clk (core_clk),
      .ext_reset_in     (sys_rst),
