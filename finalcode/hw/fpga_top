    .DEF_RPM_MOVE_THR   (90),
    .UART_BIT_PERIOD    (868),   // 100_000_000 / 115200 = 868 clocks/bit
    .TURN_DURATION      (50_000_000),   // 0.5 s lane-change turn phase
    .HOLD_DURATION      (30_000_000),   // 0.3 s straight hold between turns
    .CORRECT_DURATION   (30_000_000)    // 0.3 s corrective counter-steer
