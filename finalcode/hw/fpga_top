// ================================================================
// cfg_sender: Sends ISK_6m_default.cfg to IWR6843 at 115200 baud
// Fires once after rst_n asserts, then idles.
//
// The .cfg content is stored in a ROM (parameter array).
// Bytes are sent LSB-first, 8N1, at the configured baud rate.
// The IWR6843 expects each command terminated with \n (0x0A).
//
// To regenerate the ROM bytes from ISK_6m_default.cfg:
//   python3 gen_cfg_rom.py ISK_6m_default.cfg > cfg_rom_bytes.vh
// and `include cfg_rom_bytes.vh  OR use the hard-coded bytes below.
// ================================================================
module cfg_sender #(
    parameter integer CLK_HZ = 100_000_000,
    parameter integer BAUD   = 115200
)(
    input  wire clk,
    input  wire rst_n,
    output reg  uart_tx
);
    // Baud divider: number of clocks per bit
    localparam integer BIT_PERIOD = CLK_HZ / BAUD;  // 868 at 100 MHz/115200

    // ── CONFIG ROM ──────────────────────────────────────────────────────────
    // Generated from ISK_6m_default.cfg
    // Each entry is one ASCII byte of the .cfg file.
    // \n = 8'h0A terminates each line (required by IWR6843 CLI).
    // Includes sensorStop at start and sensorStart at end.
    // ────────────────────────────────────────────────────────────────────────
    localparam integer CFG_LEN = 1017;  // bytes from ISK_6m_default.cfg (commands only, LF-terminated)

    // ROM stored as a packed array
    reg [7:0] cfg_rom [0:CFG_LEN-1];
    integer i_init;
    initial begin
        // The cfg file content is loaded from an external hex file.
        // Place cfg_rom.hex in the same directory as this Verilog file.
        // To generate: python3 gen_cfg_rom.py ISK_6m_default.cfg cfg_rom.hex
        $readmemh("cfg_rom.hex", cfg_rom);
    end

    // ── State machine ────────────────────────────────────────────────────────
    localparam S_IDLE    = 2'd0;
    localparam S_START   = 2'd1;   // send start bit
    localparam S_DATA    = 2'd2;   // send 8 data bits
    localparam S_STOP    = 2'd3;   // send stop bit

    reg [1:0]  state;
    reg [31:0] baud_cnt;
    reg [2:0]  bit_idx;     // 0-7 data bits
    reg [31:0] rom_idx;     // current byte in cfg_rom
    reg [7:0]  tx_shift;    // current byte being shifted out
    reg        done;        // all bytes sent

    always @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin
            state    <= S_IDLE;
            baud_cnt <= 0;
            bit_idx  <= 0;
            rom_idx  <= 0;
            tx_shift <= 8'hFF;
            uart_tx  <= 1'b1;  // idle high
            done     <= 1'b0;
        end else begin
            case (state)

                S_IDLE: begin
                    uart_tx <= 1'b1;
                    if (!done) begin
                        // Start sending immediately after reset
                        tx_shift <= cfg_rom[0];
                        rom_idx  <= 0;
                        baud_cnt <= 0;
                        bit_idx  <= 0;
                        state    <= S_START;
                    end
                end

                S_START: begin
                    uart_tx <= 1'b0;   // start bit
                    if (baud_cnt >= BIT_PERIOD - 1) begin
                        baud_cnt <= 0;
                        bit_idx  <= 0;
                        state    <= S_DATA;
                    end else
                        baud_cnt <= baud_cnt + 1;
                end

                S_DATA: begin
                    uart_tx <= tx_shift[bit_idx];   // LSB first
                    if (baud_cnt >= BIT_PERIOD - 1) begin
                        baud_cnt <= 0;
                        if (bit_idx == 3'd7) begin
                            bit_idx <= 0;
                            state   <= S_STOP;
                        end else
                            bit_idx <= bit_idx + 1;
                    end else
                        baud_cnt <= baud_cnt + 1;
                end

                S_STOP: begin
                    uart_tx <= 1'b1;   // stop bit
                    if (baud_cnt >= BIT_PERIOD - 1) begin
                        baud_cnt <= 0;
                        if (rom_idx >= CFG_LEN - 1) begin
                            // All bytes sent — stay idle
                            done  <= 1'b1;
                            state <= S_IDLE;
                        end else begin
                            rom_idx  <= rom_idx + 1;
                            tx_shift <= cfg_rom[rom_idx + 1];
                            state    <= S_START;
                        end
                    end else
                        baud_cnt <= baud_cnt + 1;
                end

                default: state <= S_IDLE;
            endcase
        end
    end
endmodule
