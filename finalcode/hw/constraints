## ── False paths for asynchronous I/O ─────────────────────────────────────────
set_false_path -to   [get_ports { radar_pwm_l radar_pwm_r }]
set_false_path -to   [get_ports { radar_in1 radar_in2 radar_in3 radar_in4 }]
set_false_path -to   [get_ports { radar_buzzer radar_status_led }]
set_false_path -to   [get_ports { radar_sd_cs_n radar_sd_mosi radar_sd_sclk }]
set_false_path -to   [get_ports { radar_cfg_tx }]
set_false_path -from [get_ports { radar_uart_rxd radar_sd_miso }]
set_false_path -from [get_ports { gpio_8 }]

## ── Bitstream configuration ──────────────────────────────────────────────────
set_property BITSTREAM.GENERAL.COMPRESS     TRUE  [current_design]
set_property BITSTREAM.CONFIG.CONFIGRATE    33    [current_design]
set_property CONFIG_VOLTAGE                 3.3   [current_design]
set_property CFGBVS                         VCCO  [current_design]
set_property BITSTREAM.CONFIG.SPI_BUSWIDTH  1     [current_design]
set_property BITSTREAM.CONFIG.SPI_FALL_EDGE YES   [current_design]

## ── System clock (100 MHz) ───────────────────────────────────────────────────
set_property -dict { PACKAGE_PIN E3   IOSTANDARD LVCMOS33 } [get_ports { sys_clk }]
create_clock -period 10.000 -name sys_clk [get_ports { sys_clk }]

## ── external_clk (JB8, non‑clock pin) ────────────────────────────────────────
set_property PACKAGE_PIN J15 IOSTANDARD LVCMOS33 [get_ports external_clk]
set_property CLOCK_DEDICATED_ROUTE FALSE [get_nets external_clk_IBUF]
create_clock -period 10.000 -name external_clk [get_ports external_clk]

## ── Ethernet PHY clocks (25 MHz) ─────────────────────────────────────────────
set_property PACKAGE_PIN F15 IOSTANDARD LVCMOS33 [get_ports phy_rx_clk]
create_clock -period 40.000 -name phy_rx_clk [get_ports phy_rx_clk]

set_property PACKAGE_PIN H15 IOSTANDARD LVCMOS33 [get_ports phy_tx_clk]
create_clock -period 40.000 -name phy_tx_clk [get_ports phy_tx_clk]
