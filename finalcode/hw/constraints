## =============================================================================
##  constraints.xdc  —  Shakti Yamuna + Radar ADAS v3.0
##  Board: Arty A7-100T  (xc7a100ticsg324-1L)
##
##  RADAR ADAS v3.0 PIN PLAN (unchanged)
## =============================================================================

set_property CLOCK_DEDICATED_ROUTE BACKBONE [get_nets sys_clk_IBUF]

## ── PMOD JA — IWR6843 UART RX + SD Card SPI ─────────────────────────────────
set_property -dict { PACKAGE_PIN G13  IOSTANDARD LVCMOS33 } [get_ports { radar_uart_rxd }] ;# JA1
set_property PULLUP  true [get_ports { radar_uart_rxd }]
set_property -dict { PACKAGE_PIN B11  IOSTANDARD LVCMOS33 } [get_ports { radar_sd_cs_n  }] ;# JA2
set_property -dict { PACKAGE_PIN A11  IOSTANDARD LVCMOS33 } [get_ports { radar_sd_mosi  }] ;# JA3
set_property -dict { PACKAGE_PIN D12  IOSTANDARD LVCMOS33 } [get_ports { radar_sd_miso  }] ;# JA4
set_property PULLUP  true [get_ports { radar_sd_miso }]
set_property -dict { PACKAGE_PIN D13  IOSTANDARD LVCMOS33 } [get_ports { radar_sd_sclk  }] ;# JA7

## ── PMOD JB — I2C0 + cfg_sender TX ───────────────────────────────────────────
set_property -dict { PACKAGE_PIN E15  IOSTANDARD LVCMOS33 } [get_ports { i2c0_sda       }] ;# JB1
set_property -dict { PACKAGE_PIN E16  IOSTANDARD LVCMOS33 } [get_ports { i2c0_scl       }] ;# JB2
set_property -dict { PACKAGE_PIN D15  IOSTANDARD LVCMOS33 } [get_ports { radar_cfg_tx   }] ;# JB3
set_property -dict { PACKAGE_PIN C15  IOSTANDARD LVCMOS33 } [get_ports { gpio_14        }] ;# JB4
set_property PULLDOWN true [get_ports { gpio_14 }]
set_property -dict { PACKAGE_PIN J15  IOSTANDARD LVCMOS33 } [get_ports { external_clk   }] ;# JB8

## ── PMOD JC — GPTimers (unchanged) ──────────────────────────────────────────
set_property -dict { PACKAGE_PIN U12  IOSTANDARD LVCMOS33 } [get_ports { gptimer0_in  }]
set_property -dict { PACKAGE_PIN V12  IOSTANDARD LVCMOS33 } [get_ports { gptimer0_out }]
set_property -dict { PACKAGE_PIN V10  IOSTANDARD LVCMOS33 } [get_ports { gptimer1_in  }]
set_property -dict { PACKAGE_PIN V11  IOSTANDARD LVCMOS33 } [get_ports { gptimer1_out }]
set_property -dict { PACKAGE_PIN U14  IOSTANDARD LVCMOS33 } [get_ports { gptimer2_in  }]
set_property -dict { PACKAGE_PIN V14  IOSTANDARD LVCMOS33 } [get_ports { gptimer2_out }]
set_property -dict { PACKAGE_PIN T13  IOSTANDARD LVCMOS33 } [get_ports { gptimer3_in  }]
set_property -dict { PACKAGE_PIN U13  IOSTANDARD LVCMOS33 } [get_ports { gptimer3_out }]

## ── PMOD JD — Radar ADAS v3.0 (dedicated) ────────────────────────────────────
set_property -dict { PACKAGE_PIN D4   IOSTANDARD LVCMOS33 } [get_ports { radar_in1        }]
set_property -dict { PACKAGE_PIN D3   IOSTANDARD LVCMOS33 } [get_ports { radar_in2        }]
set_property -dict { PACKAGE_PIN F4   IOSTANDARD LVCMOS33 } [get_ports { radar_in3        }]
set_property -dict { PACKAGE_PIN F3   IOSTANDARD LVCMOS33 } [get_ports { radar_in4        }]
set_property -dict { PACKAGE_PIN E2   IOSTANDARD LVCMOS33 } [get_ports { radar_pwm_l      }]
set_property -dict { PACKAGE_PIN D2   IOSTANDARD LVCMOS33 } [get_ports { radar_pwm_r      }]
set_property -dict { PACKAGE_PIN H2   IOSTANDARD LVCMOS33 } [get_ports { radar_buzzer     }]
set_property -dict { PACKAGE_PIN G2   IOSTANDARD LVCMOS33 } [get_ports { radar_status_led }]

## Drive strength & slew (unchanged)
set_property DRIVE 12 [get_ports { radar_pwm_l radar_pwm_r }]
set_property DRIVE 12 [get_ports { radar_in1 radar_in2 radar_in3 radar_in4 }]
set_property DRIVE  8 [get_ports { radar_buzzer radar_status_led }]
set_property DRIVE  8 [get_ports { radar_sd_mosi radar_sd_sclk radar_sd_cs_n }]
set_property DRIVE  8 [get_ports { radar_cfg_tx }]
set_property SLEW FAST [get_ports { radar_pwm_l radar_pwm_r }]
set_property SLEW FAST [get_ports { radar_sd_mosi radar_sd_sclk }]
set_property SLEW SLOW [get_ports { radar_in1 radar_in2 radar_in3 radar_in4 }]
set_property SLEW SLOW [get_ports { radar_buzzer radar_status_led radar_cfg_tx }]

